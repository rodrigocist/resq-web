rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Merchants: readable by all, writable only by owner
    match /merchants/{merchantId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == merchantId;
    }

    // Surprise bags: readable by all, writable only by the owning merchant
    match /surprise_bags/{bagId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.merchant_id == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.merchant_id == request.auth.uid;
    }

    // Orders: users can read their own, merchants can read orders for their bags
    match /orders/{orderId} {
      allow read: if request.auth != null
        && (resource.data.user_id == request.auth.uid
            || resource.data.merchant_id == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
    }
  }
}
